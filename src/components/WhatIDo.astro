---
import { getPublishedWriting, getReadingTime } from "@/lib/writing";
import FormattedDate from "@/components/FormattedDate.astro";
import { Icon } from "astro-icon/components";

const posts = (await getPublishedWriting()).slice(0, 6);
const bgClasses = [
  "bg-pgreen rounded-full",
  "bg-pblue rounded-2xl",
  "bg-ppink rounded-lg",
  "bg-pyellow rounded-md",
];
---

<section class="flex flex-col items-center text-center gap-4">
  <p class="text-pblack">From the garden</p>
  <h2 class="text-4xl font-bold">Recent Writing</h2>
  <ul
    class="flex flex-wrap max-w-[940px] mx-auto justify-center md:justify-start gap-8 py-20"
  >
    {
      posts.map((post, index) => {
        const iconClass = bgClasses[index % bgClasses.length];
        const readingTime = getReadingTime(post);
        return (
          <li class="w-72 text-left rounded-3xl border-[3px] border-black bg-white shadow-card group hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-hover transition px-4 py-6 flex flex-col gap-6">
            <a aria-label={post.data.title} href={`/writing/${post.id}/`} class="flex flex-col gap-4">
              <div
                class={`${iconClass} text-4xl p-2 self-start border-1 border-black shadow-card1 group-hover:shadow-card transition`}
              >
                <Icon name={post.data.icon ?? "web"} />
              </div>
              <h2 class="text-xl font-semibold">{post.data.title}</h2>
              <p class="date -mt-4 text-sm font-light">
                <FormattedDate date={post.data.pubDate} /> · {readingTime.text}
              </p>
            </a>
            <div set:html={post.data.description} />
          </li>
        );
      })
    }
  </ul>
  <a href="/writing" class="rounded-xl border-[3px] border-black bg-pyellow px-5 py-3 font-bold shadow-card transition hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-hover">
    Browse all writing
  </a>
</section>
