---
import Link from "./HeaderLink.astro";
import { Icon } from "astro-icon/components";
import ThemeSwitcher from "./ThemeSwitcher.astro";
import ThemeLoader from "./ThemeLoader.astro";

const links = [
  { href: "/", text: "Home", style: "primary" },
  { href: "/writing", text: "Writing", style: "secondary" },
  { href: "/projects", text: "Projects", style: "tertiary" },
  { href: "/knowledge", text: "Knowledge", style: "primary" },
  { href: "/about", text: "About", style: "secondary" },
] as const;
---

<!--
  Header component with responsive navigation.
  Uses a CSS-only approach for the mobile hamburger menu (no JavaScript).
-->
<ThemeLoader />
<header>
  <nav
    class="flex container mx-auto md:p-10 px-4 py-6 items-center justify-between"
  >
    <!-- Logo / Brand + Theme Switcher -->
    <div class="flex items-center gap-3">
      <a class="flex items-center gap-2" href="/" aria-label="Home">
        <p class="font-kablamo text-ppink text-4xl md:text-5xl">S</p>
        <p class="pt-2 md:text-lg font-semibold flex">
          <span class="hidden md:block">seas</span>Kanon
        </p>
      </a>
      <ThemeSwitcher />
    </div>

    <!-- Desktop Navigation -->
    <ul class="items-center md:gap-4 text-nowrap hidden md:flex">
      {links.map((link) => (
        <li><Link href={link.href} text={link.text} style={link.style} /></li>
      ))}
    </ul>

    <!-- Mobile Navigation (CSS-only hamburger menu) -->
    <div class="md:hidden z-40">
      <!--
        Hidden checkbox that stores the menu state (open/closed).
        The 'peer' class allows sibling elements to style based on its state.
      -->
      <input type="checkbox" id="menu-toggle" class="hidden peer" />

      <!-- Hamburger button -->
      <label
        for="menu-toggle"
        class="relative cursor-pointer"
        aria-label="Open menu"
      >
        <Icon
          name="menu"
          class="w-10 h-10 font-bold"
          transition:animate="fade"
        />
      </label>

      <!--
        Mobile menu overlay.
        Starts off-screen (-translate-y-full) and slides in when checked.
        The 'peer-checked:translate-y-0' applies when the checkbox is checked.
      -->
      <div
        class="fixed top-0 left-0 w-full h-full bg-card -translate-y-full transition-transform duration-300 ease-in-out peer-checked:translate-y-0"
      >
        <ul
          class="flex flex-col items-center justify-center h-full gap-8 text-nowrap"
        >
          {links.map((link) => (
            <li><Link href={link.href} text={link.text} style={link.style} /></li>
          ))}
        </ul>
      </div>
    </div>
  </nav>
</header>
