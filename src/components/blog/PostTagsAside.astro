---
import type { TaxonomyCount } from "@/lib/writing";

interface Props {
  tags: TaxonomyCount[];
  activeSlugs: string[];
}

const { tags, activeSlugs } = Astro.props;
---

<section class="rounded-3xl border-[3px] border-black bg-[#FFF0F5] p-5 shadow-card">
  <span
    class="inline-block rounded-lg border-2 border-black bg-ppink px-4 py-1.5 text-xl font-bold shadow-card1"
  >
    Tags
  </span>

  {tags.length > 0 ? (
    <div class="mt-4 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <a
          href={`/writing/tags/${tag.slug}/`}
          class:list={[
            "inline-flex items-center gap-1.5 rounded-full border-2 border-black px-3 py-1 text-sm font-semibold shadow-card1 transition hover:-translate-y-0.5 hover:shadow-card",
            activeSlugs.includes(tag.slug) ? "bg-white" : "bg-white",
          ]}
        >
          <span>#{tag.name}</span>
          <span class="text-xs text-pblack">{tag.count}</span>
        </a>
      ))}
    </div>
  ) : (
    <p class="mt-4 text-sm text-pblack">No tags yet.</p>
  )}
</section>
