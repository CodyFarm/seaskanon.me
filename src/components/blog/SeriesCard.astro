---
import type { TaxonomyCount } from "@/lib/writing";

interface Props {
  series: TaxonomyCount[];
  activeSlug?: string;
}

const { series, activeSlug = "" } = Astro.props;
---

<section class="rounded-3xl border-[3px] border-border-main bg-series-bg p-5 shadow-card">
  <a
    href="/writing"
    class="inline-block rounded-lg border-2 border-border-main bg-series-button px-4 py-1.5 text-xl font-bold shadow-card1 transition ease-in-out hover:-translate-y-0.5 hover:shadow-pyellowHover"
  >
    Series
  </a>
  {series.length > 0 ? (
    <ul class="mt-4 flex flex-col gap-2">
      {series.map((item) => (
        <li>
          <a
            href={`/writing/series/${item.slug}/`}
            class:list={[
              "flex items-center justify-between rounded-xl border-2 border-border-main px-3 py-2 text-sm font-semibold shadow-card1 transition hover:-translate-y-0.5 hover:shadow-card",
              item.slug === activeSlug ? "bg-card" : "bg-card",
            ]}
          >
            <span>{item.name}</span>
            <span class="rounded-full border border-border-main bg-pblue px-2 py-0.5 text-xs">{item.count}</span>
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p class="mt-4 text-sm text-pblack">Series will grow with longer notes and rebuild logs.</p>
  )}
</section>
