---
import type { WritingPost } from "@/lib/writing";
import {
  getNormalizedPostCover,
  getPostUrl,
  getReadingTime,
  getFirstLetterColor,
} from "@/lib/writing";
import { getHeroImageLoader } from "@/lib/images";
import FormattedDate from "@/components/FormattedDate.astro";
import PostHeroImage from "@/components/blog/PostHeroImage.astro";

interface Props {
  post: WritingPost;
}

const { post } = Astro.props;
const cover = getNormalizedPostCover(post);
const imageLoader = getHeroImageLoader(cover);
const hasImage = Boolean(imageLoader || (cover && !cover.startsWith("/src/")));
const readingTime = getReadingTime(post);
const effectiveCategory = post.data.category || post.data.categories;
const firstLetter = getFirstLetterColor(post.data.firstLetterColor);
const titleFirstChar = post.data.title.charAt(0);
const titleRest = post.data.title.slice(1);
---

<article
  class="group h-full rounded-3xl border-[3px] border-border-main bg-card shadow-card transition-transform duration-200 hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-hover"
>
  <a
    href={getPostUrl(post)}
    aria-label={post.data.title}
    class="flex h-full flex-col gap-2 p-5"
  >
    {/* Cover area */}
    <div
      class="relative h-44 overflow-hidden rounded-2xl border-[3px] border-border-main bg-card-soft"
    >
      <PostHeroImage
        post={post}
        alt=""
        class="h-44 w-full object-cover transition duration-300 group-hover:scale-105"
        widths={[360, 520, 720]}
        sizes="(max-width: 768px) 100vw, 520px"
        quality={80}
      >
        <div class="flex h-full items-center justify-center p-6 text-center">
          <span
            class="font-kablamo text-7xl"
            style={`color: ${firstLetter.style}`}
          >
            {titleFirstChar}
          </span>
        </div>
      </PostHeroImage>

      {
        hasImage && (
          <div
            class="pointer-events-none absolute inset-x-0 bottom-0 p-5"
            style="background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);"
          >
            <h2
              class="text-lg font-black leading-tight text-text-inverse line-clamp-2 break-words md:text-xl"
            >
              <span
                class="font-kablamo"
                style={`color: ${firstLetter.style}`}>{titleFirstChar}</span
              >{titleRest}
            </h2>
          </div>
        )
      }
    </div>

    {/* Title in body for cards without a cover image */}
    {
      !hasImage && (
        <h2 class="text-lg font-black leading-tight text-pblack line-clamp-2 break-words md:text-xl">
          <span class="font-kablamo" style={`color: ${firstLetter.style}`}>
            {titleFirstChar}
          </span>
          {titleRest}
        </h2>
      )
    }

    {/* Description in body, dark text */}
    {
      post.data.description && (
        <p
          class="text-sm leading-snug text-pblack line-clamp-2 break-words"
          set:html={post.data.description}
        />
      )
    }

    {/* Metadata bar */}
    <div class="flex flex-wrap items-center gap-2 text-sm text-pblack">
      <FormattedDate date={post.data.pubDate} />
      <span aria-hidden="true">·</span>
      <span>{readingTime.text}</span>
      {
        effectiveCategory && (
          <>
            <span aria-hidden="true">·</span>
            <span class="rounded-full border border-border-main bg-pyellow px-2 py-0.5 text-xs font-semibold text-text-main transition hover:border-ppink hover:text-ppink">
              {effectiveCategory}
            </span>
          </>
        )
      }
    </div>

    {/* Tags */}
    {
      post.data.tags && post.data.tags.length > 0 && (
        <ul class="flex flex-wrap gap-2" aria-label="Tags">
          {post.data.tags.slice(0, 5).map((tag) => (
            <li class="rounded-full border border-border-main bg-card px-3 py-1 text-xs font-semibold text-text-main shadow-card1 transition hover:border-pgreen hover:text-pgreen">
              #{tag}
            </li>
          ))}
        </ul>
      )
    }
  </a>
</article>
