---
import type { WritingPost } from "@/lib/writing";
import { getPostCover, getPostUrl, getReadingTime } from "@/lib/writing";
import FormattedDate from "@/components/FormattedDate.astro";
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  post: WritingPost;
  color?: "blue" | "green" | "pink" | "yellow";
}

const { post, color = "blue" } = Astro.props;
const cover = getPostCover(post);
const readingTime = getReadingTime(post);
const bgByColor = {
  blue: "bg-pblue",
  green: "bg-pgreen",
  pink: "bg-ppink",
  yellow: "bg-pyellow",
};
const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/*.{webp,jpeg,jpg,png,gif}");
const imageLoader = cover ? images[cover] : undefined;
---

<article class="group h-full rounded-3xl border-[3px] border-black bg-white shadow-card transition hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-hover">
  <a href={getPostUrl(post)} aria-label={post.data.title} class="flex h-full flex-col gap-5 p-5">
    <div class:list={["relative min-h-44 overflow-hidden rounded-2xl border-[3px] border-black", bgByColor[color]]}>
      {imageLoader ? (
        <Picture
          src={imageLoader()}
          alt={post.data.title}
          class="h-44 w-full object-cover transition duration-300 group-hover:scale-105"
          format="webp"
          widths={[360, 520, 720]}
          sizes="(max-width: 768px) 100vw, 520px"
          quality={80}
        />
      ) : (
        <div class="flex h-44 items-center justify-center p-6 text-center">
          <span class="font-kablamo text-7xl text-pblack">{post.data.title.charAt(0)}</span>
        </div>
      )}
    </div>

    <div class="flex flex-wrap items-center gap-2 text-sm text-pblack">
      <FormattedDate date={post.data.pubDate} />
      <span aria-hidden="true">•</span>
      <span>{readingTime.text}</span>
      {post.data.category && (
        <>
          <span aria-hidden="true">•</span>
          <span class="rounded-full border border-black bg-pyellow px-2 py-0.5 text-black">{post.data.category}</span>
        </>
      )}
    </div>

    <div class="flex flex-1 flex-col gap-3">
      <h2 class="text-2xl font-bold leading-tight text-black">{post.data.title}</h2>
      <p class="line-clamp-3 text-pblack" set:html={post.data.description} />
    </div>

    {post.data.tags.length > 0 && (
      <ul class="flex flex-wrap gap-2" aria-label="Tags">
        {post.data.tags.slice(0, 5).map((tag) => (
          <li class="rounded-full border border-black bg-white px-3 py-1 text-xs font-semibold text-black shadow-card1">
            #{tag}
          </li>
        ))}
      </ul>
    )}
  </a>
</article>
