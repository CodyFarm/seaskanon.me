---
import { formatNumber } from "@/lib/writing";

interface Props {
  stats: {
    totalPosts: number;
    totalCategories: number;
    totalTags: number;
    totalWords: number;
  };
}

const { stats } = Astro.props;
const items = [
  ["Posts", stats.totalPosts],
  ["Categories", stats.totalCategories],
  ["Tags", stats.totalTags],
  ["Words", stats.totalWords],
];
const barColors = ["bg-pblue", "bg-pgreen", "bg-ppink", "bg-pyellow"];

---
<section class="rounded-3xl border-[3px] border-black bg-white p-5 shadow-card">
  <h2 class="font-kablamo text-2xl">Statistics</h2>
  <dl class="mt-4 grid grid-cols-2 gap-3">
    {items.map(([label, value], i) => (
      <div class="rounded-2xl border-2 border-black bg-white p-3 shadow-card1">
        <dt class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wide text-pblack">
          <span class:list={["inline-block h-4 w-1 rounded-full", barColors[i]]}></span>
          {label}
        </dt>
        <dd class="text-2xl font-black text-black">{formatNumber(value as number)}</dd>
      </div>
    ))}
  </dl>
</section>
