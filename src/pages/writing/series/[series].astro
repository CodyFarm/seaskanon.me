---
import BaseHead from "@/components/BaseHead.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ArticleCard from "@/components/blog/ArticleCard.astro";
import Sidebar from "@/components/blog/Sidebar.astro";
import { SITE_TITLE } from "@/consts";
import { getTaxonomyDescription } from "@/data/taxonomyDescriptions";
import {
  getCategoryCounts,
  getPublishedWriting,
  getSeriesCounts,
  getTagCounts,
  getWritingStats,
  matchesTaxonomySlug,
  type TaxonomyCount,
  type WritingPost,
} from "@/lib/writing";

export async function getStaticPaths() {
  const posts = await getPublishedWriting();
  const series = getSeriesCounts(posts);

  return series.map((item) => ({
    params: { series: item.slug },
    props: { series: item },
  }));
}

export const prerender = true;

const { series } = Astro.props as { series: TaxonomyCount };
const posts = await getPublishedWriting();
const filteredPosts = posts
  .filter((post: WritingPost) => matchesTaxonomySlug(post.data.series, series.slug))
  .sort((a, b) => {
    const aId = parseInt(a.data.series_id ?? "0", 10);
    const bId = parseInt(b.data.series_id ?? "0", 10);
    return aId - bId;
  });
const stats = getWritingStats(posts);
const categories = getCategoryCounts(posts);
const tags = getTagCounts(posts);
const allSeries = getSeriesCounts(posts);
const description = getTaxonomyDescription("series", series.slug);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${series.name} | Series | Writing | ${SITE_TITLE}`} description={`Writing in the ${series.name} series.`} />
  </head>
  <body>
    <Header />
    <main class="container mx-auto px-4 py-12 md:px-10 md:py-20">
      <section class="mx-auto mb-10 max-w-5xl rounded-3xl border-[3px] border-black bg-[#FDF5E6] p-8 shadow-card">
        <p class="font-semibold text-pblack">Series</p>
        <h1 class="mt-2 text-5xl font-black md:text-7xl">{series.name}</h1>
        <p class="mt-4 text-lg text-black">
          {filteredPosts.length} article{filteredPosts.length === 1 ? "" : "s"} in this series.
          {description && <span class="mt-2 block text-base leading-7 text-pblack">{description}</span>}
        </p>
      </section>

      <div class="mx-auto grid max-w-6xl gap-8 sidebar-grid sidebar-grid--left">
        <Sidebar stats={stats} categories={categories} tags={tags} series={allSeries} activeSeries={series.slug} />
        <section class="grid gap-6 md:grid-cols-2">
          {filteredPosts.map((post) => (
            <ArticleCard post={post} />
          ))}
        </section>
      </div>
    </main>
    <Footer />
  </body>
</html>
