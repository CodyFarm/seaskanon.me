---
import BaseHead from "@/components/BaseHead.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ArticleCard from "@/components/blog/ArticleCard.astro";
import PageBanner from "@/components/PageBanner.astro";
import Sidebar from "@/components/blog/Sidebar.astro";
import SearchBox from "@/components/blog/SearchBox.astro";
import Pagination from "@/components/blog/Pagination.astro";
import CapsulePlayer from "@/components/blog/CapsulePlayer.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "@/consts";
import {
  getCategoryCounts,
  getPublishedWriting,
  getSeriesCounts,
  getTagCounts,
  getWritingStats,
} from "@/lib/writing";

const posts = await getPublishedWriting();
const stats = getWritingStats(posts);
const categories = getCategoryCounts(posts);
const tags = getTagCounts(posts);
const series = getSeriesCounts(posts);
const pageSize = 6;
const totalPages = Math.ceil(posts.length / pageSize);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Writing | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="container mx-auto px-4 py-12 md:px-10 md:py-20">
      <PageBanner
        label="Writing"
        title="Notes, logs, and essays for a growing digital garden."
        description="按时记录学习、开发、阅读、项目复盘与文化随笔。Regularly jotting down notes on studying, development, reading, project reviews, and cultural reflections."
      />

      <div class="mx-auto grid max-w-6xl gap-8 sidebar-grid sidebar-grid--left">
        <Sidebar stats={stats} categories={categories} tags={tags} series={series} showToggle={false} />
        <section class="flex min-w-0 flex-col gap-8">
          <SearchBox />
          {posts.length > 0 ? (
            <>
              <div class="min-w-0 grid gap-8 md:grid-cols-2 md:gap-x-8 md:gap-y-10">
                {Array.from({ length: totalPages }, (_, i) => (
                  <div class="contents page-group" data-page={i + 1}>
                    {posts
                      .slice(i * pageSize, (i + 1) * pageSize)
                      .map((post) => (
                        <ArticleCard post={post} />
                      ))}
                  </div>
                ))}
              </div>
              {totalPages > 1 && <Pagination totalPages={totalPages} />}
            </>
          ) : (
            <div class="rounded-3xl border-[3px] border-border-main bg-ppink p-8 shadow-card">
              <h2 class="text-2xl font-bold">No writing yet</h2>
              <p class="mt-2 text-pblack">Published articles will appear here.</p>
            </div>
          )}
        </section>
      </div>
    </main>
    <Footer />
    <CapsulePlayer />
  </body>
</html>
