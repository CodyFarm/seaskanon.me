---
import BaseHead from "@/components/BaseHead.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ArticleCard from "@/components/blog/ArticleCard.astro";
import Sidebar from "@/components/blog/Sidebar.astro";
import { SITE_TITLE } from "@/consts";
import {
  getCategoryCounts,
  getPublishedWriting,
  getSeriesCounts,
  getTagCounts,
  getWritingStats,
  matchesTaxonomySlug,
  type TaxonomyCount,
  type WritingPost,
} from "@/lib/writing";

export async function getStaticPaths() {
  const posts = await getPublishedWriting();
  const categories = getCategoryCounts(posts);

  return categories.map((category) => ({
    params: { category: category.slug },
    props: { category },
  }));
}

export const prerender = true;

const { category } = Astro.props as { category: TaxonomyCount };
const posts = await getPublishedWriting();
const filteredPosts = posts.filter((post: WritingPost) => matchesTaxonomySlug(post.data.category, category.slug));
const stats = getWritingStats(posts);
const categories = getCategoryCounts(posts);
const tags = getTagCounts(posts);
const series = getSeriesCounts(posts);
const colors = ["blue", "green", "pink", "yellow"] as const;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${category.name} | Writing | ${SITE_TITLE}`} description={`Writing filed under ${category.name}.`} />
  </head>
  <body>
    <Header />
    <main class="container mx-auto px-4 py-12 md:px-10 md:py-20">
      <section class="mx-auto mb-10 max-w-5xl rounded-3xl border-[3px] border-black bg-pgreen p-8 shadow-card">
        <p class="font-semibold text-pblack">Category</p>
        <h1 class="mt-2 text-5xl font-black md:text-7xl">{category.name}</h1>
        <p class="mt-4 text-lg text-black">{filteredPosts.length} article{filteredPosts.length === 1 ? "" : "s"} in this category.</p>
      </section>

      <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[320px_1fr]">
        <Sidebar stats={stats} categories={categories} tags={tags} series={series} activeCategory={category.slug} />
        <section class="grid gap-6 md:grid-cols-2">
          {filteredPosts.map((post, index) => (
            <ArticleCard post={post} color={colors[index % colors.length]} />
          ))}
        </section>
      </div>
    </main>
    <Footer />
  </body>
</html>
