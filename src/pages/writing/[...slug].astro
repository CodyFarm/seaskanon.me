---
import { type CollectionEntry } from "astro:content";
import { render } from "astro:content";
import WritingPost from "@/layouts/WritingPost.astro";
import {
  getPublishedWriting,
  getCategoryCounts,
  getTagCounts,
  getSeriesPosts,
} from "@/lib/writing";

export async function getStaticPaths() {
  const posts = await getPublishedWriting();

  return posts.map((post) => ({
    params: { slug: post.id },
    props: {
      post,
      allPosts: posts,
      relatedPosts: posts.filter((candidate) => candidate.id !== post.id),
    },
  }));
}

export const prerender = true;

type Props = {
  post: CollectionEntry<"blog">;
  allPosts: CollectionEntry<"blog">[];
  relatedPosts: CollectionEntry<"blog">[];
};

const { post, allPosts, relatedPosts } = Astro.props;
const { Content } = await render(post);

// Compute taxonomy data for post sidebar modules
const allCategories = getCategoryCounts(allPosts);
const allTags = getTagCounts(allPosts);
const seriesPosts =
  post.data.series
    ? getSeriesPosts(allPosts, post.data.series)
    : [];
---

<WritingPost
  post={post}
  relatedPosts={relatedPosts}
  allCategories={allCategories}
  allTags={allTags}
  seriesPosts={seriesPosts}
>
  <Content />
</WritingPost>
