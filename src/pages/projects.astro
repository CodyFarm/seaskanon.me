---
import BaseHead from "@/components/BaseHead.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import PageBanner from "@/components/PageBanner.astro";
import ProjectGallery from "@/components/projects/ProjectGallery.astro";
import { SITE_TITLE } from "@/consts";
import CapsulePlayer from "@/components/blog/CapsulePlayer.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Projects | ${SITE_TITLE}`} description="Projects, experiments, and course work from seasKanon." />
  </head>
  <body>
    <Header />
    <main class="projects-page">
      <div class="projects-stage" data-stage>
        <div class="projects-banner">
          <PageBanner
            label="Projects"
            title="Work worth keeping, not just showing."
            description="This page reserves a dedicated home for SageRoute, mathematical modeling, course work, research experiments, and future demos."
          />
        </div>
        <div class="projects-gallery-wrapper">
          <ProjectGallery />
        </div>
      </div>
    </main>
    <Footer />
    <CapsulePlayer />

    <script is:inline data-astro-rerun>
      (function () {
        function init() {
          const stage = document.querySelector('[data-stage]');
          if (!stage || stage.__stageInited) return;
          stage.__stageInited = true;

          const header = document.querySelector('header');
          function setHeaderHeight() {
            const h = header ? header.offsetHeight : 64;
            document.documentElement.style.setProperty('--header-height', h + 'px');
          }
          setHeaderHeight();
          window.addEventListener('resize', setHeaderHeight);

          let shown = false;
          let lock = false;
          let accum = 0;
          let resetTimer = null;
          const THRESHOLD = 70;
          const LOCK_MS = 700;

          function show() {
            if (shown) return;
            shown = true;
            stage.classList.add('is-shown');
          }

          function hide() {
            if (!shown) return;
            shown = false;
            stage.classList.remove('is-shown');
          }

          function trigger(direction) {
            if (lock) return false;
            if (direction === 'down' && !shown) {
              show();
            } else if (direction === 'up' && shown && window.scrollY <= 0) {
              hide();
            } else {
              return false;
            }
            lock = true;
            accum = 0;
            window.setTimeout(() => { lock = false; }, LOCK_MS);
            return true;
          }

          function onWheel(e) {
            if (window.innerWidth <= 768) return;
            const dy = e.deltaY;
            if (Math.abs(dy) < 2) return;
            accum += dy;
            if (resetTimer) clearTimeout(resetTimer);
            resetTimer = window.setTimeout(() => { accum = 0; }, 120);

            if (accum > THRESHOLD) {
              if (trigger('down')) e.preventDefault();
            } else if (accum < -THRESHOLD) {
              if (trigger('up')) e.preventDefault();
            }
          }

          function onKey(e) {
            if (window.innerWidth <= 768) return;
            if (e.key === 'ArrowDown' || e.key === 'PageDown') {
              e.preventDefault();
              trigger('down');
            } else if (e.key === 'ArrowUp' || e.key === 'PageUp') {
              e.preventDefault();
              trigger('up');
            }
          }

          let touchStartY = 0;
          function onTouchStart(e) {
            touchStartY = e.touches[0].clientY;
          }
          function onTouchEnd(e) {
            if (window.innerWidth <= 768) return;
            const dy = touchStartY - e.changedTouches[0].clientY;
            if (dy > 60) trigger('down');
            else if (dy < -60) trigger('up');
          }

          stage.addEventListener('wheel', onWheel, { passive: false });
          stage.addEventListener('keydown', onKey);
          stage.addEventListener('touchstart', onTouchStart, { passive: true });
          stage.addEventListener('touchend', onTouchEnd, { passive: true });
          stage.setAttribute('tabindex', '0');
        }

        document.addEventListener('DOMContentLoaded', init);
        document.addEventListener('astro:page-load', init);
      })();
    </script>
  </body>
</html>
