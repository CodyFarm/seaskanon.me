---
import BaseHead from "@/components/BaseHead.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "@/consts";
import { Icon } from "astro-icon/components";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`About | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="container mx-auto px-4 py-12 md:px-10 md:py-20">
      <section class="mx-auto grid max-w-5xl gap-8 md:grid-cols-[1fr_320px]">
        <div class="rounded-3xl border-[3px] border-black bg-pyellow p-8 shadow-card">
          <p class="font-semibold text-pblack">About</p>
          <h1 class="mt-2 text-5xl font-black leading-tight md:text-7xl">seasKanon, 四季的卡农。</h1>
          <div class="mt-6 flex flex-col gap-5 text-lg leading-8 text-black">
            <p>
              I am Cody, a mathematics student building a long-term personal site for writing, projects, and knowledge. This place is meant to feel like a handmade desk: notes, cards, experiments, and a few colorful reminders of what I am learning.
            </p>
            <p>
              The site grows around mathematics, software engineering, operations research, reading, travel, and cultural notes. Writing is the chronological stream; Projects are the things I build; Knowledge will become a linked Quartz garden.
            </p>
          </div>
        </div>

        <aside class="flex flex-col gap-5">
          <div class="rounded-3xl border-[3px] border-black bg-pblue p-5 shadow-card">
            <div class="flex h-24 w-24 items-center justify-center rounded-full border-[3px] border-black bg-ppink font-kablamo text-6xl shadow-card1">S</div>
            <h2 class="mt-5 text-2xl font-black">Cody / seasKanon</h2>
            <p class="mt-2 text-pblack">Math, code, reading, culture, and slow knowledge work.</p>
          </div>
          <div class="rounded-3xl border-[3px] border-black bg-white p-5 shadow-card">
            <h2 class="text-xl font-bold">Find me</h2>
            <div class="mt-4 flex items-center gap-4 text-3xl">
              <a href="/writing" class="rounded-full border-2 border-black bg-pyellow p-2 shadow-card1 transition hover:-translate-y-0.5 hover:shadow-card" aria-label="Writing">
                <Icon name="web" />
              </a>
              <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="rounded-full border-2 border-black bg-pblue p-2 shadow-card1 transition hover:-translate-y-0.5 hover:shadow-card" aria-label="GitHub">
                <Icon name="github" />
              </a>
              <a href="https://www.linkedin.com" target="_blank" rel="noopener noreferrer" class="rounded-full border-2 border-black bg-pgreen p-2 shadow-card1 transition hover:-translate-y-0.5 hover:shadow-card" aria-label="LinkedIn">
                <Icon name="linkedin" />
              </a>
            </div>
          </div>
        </aside>
      </section>
    </main>
    <Footer />
  </body>
</html>
