---
import type { CollectionEntry } from "astro:content";
import BaseHead from "@/components/BaseHead.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import ArticleCard from "@/components/blog/ArticleCard.astro";
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";
import {
  getPostCover,
  getReadingTime,
  getPublishedWriting,
  type WritingPost,
} from "@/lib/writing";

type Props = CollectionEntry<"blog">["data"] & {
  post: WritingPost;
  relatedPosts?: WritingPost[];
};

const { post, relatedPosts = [] } = Astro.props;
const { title, description, pubDate, updatedDate, category, tags, series } = post.data;
const cover = getPostCover(post);
const readingTime = getReadingTime(post);
const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/*.{webp,jpeg,jpg,png,gif}");
const imageLoader = cover ? images[cover] : undefined;
const colors = ["green", "pink", "yellow", "blue"] as const;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />
    <main class="container mx-auto px-4 py-10 md:px-10 md:py-16">
      <article class="mx-auto max-w-5xl">
        <header class="rounded-3xl border-[3px] border-black bg-white p-5 shadow-card md:p-8">
          <div class="overflow-hidden rounded-3xl border-[3px] border-black bg-pblue">
            {imageLoader ? (
              <Picture
                src={imageLoader()}
                alt={title}
                class="h-72 w-full object-cover md:h-96"
                format="webp"
                widths={[480, 720, 1000, 1280]}
                sizes="(max-width: 768px) 100vw, 1000px"
                quality={82}
              />
            ) : (
              <div class="flex h-72 items-center justify-center bg-pblue md:h-96">
                <span class="font-kablamo text-9xl text-pblack">{title.charAt(0)}</span>
              </div>
            )}
          </div>

          <div class="mt-6 flex flex-wrap items-center gap-2 text-sm font-semibold text-pblack">
            <FormattedDate date={pubDate} />
            <span aria-hidden="true">•</span>
            <span>{readingTime.text}</span>
            <span aria-hidden="true">•</span>
            <span>{readingTime.words.toLocaleString()} words</span>
            {updatedDate && (
              <>
                <span aria-hidden="true">•</span>
                <span>Updated <FormattedDate date={updatedDate} /></span>
              </>
            )}
          </div>

          <h1 class="mt-4 text-5xl font-black leading-tight text-black md:text-7xl">
            <span class="font-kablamo text-ppink">{title.charAt(0)}</span>{title.slice(1)}
          </h1>
          <p class="mt-4 max-w-3xl text-lg leading-8 text-pblack" set:html={description} />

          <div class="mt-6 flex flex-wrap gap-2">
            {category && <a href={`/writing/categories/${category.toLocaleLowerCase().replace(/\s+/g, "-")}/`} class="rounded-full border-2 border-black bg-pyellow px-3 py-1 text-sm font-bold shadow-card1">{category}</a>}
            {series && <span class="rounded-full border-2 border-black bg-pblue px-3 py-1 text-sm font-bold shadow-card1">Series: {series}</span>}
            {tags.map((tag) => (
              <a href={`/writing/tags/${tag.toLocaleLowerCase().replace(/\s+/g, "-")}/`} class="rounded-full border-2 border-black bg-pgreen px-3 py-1 text-sm font-bold shadow-card1">#{tag}</a>
            ))}
          </div>
        </header>

        <div class="mt-10 grid gap-8 lg:grid-cols-[1fr_280px]">
          <div class="prose prose-lg max-w-none rounded-3xl border-[3px] border-black bg-white p-6 shadow-card md:p-10">
            <slot />
          </div>

          <aside class="flex flex-col gap-5 lg:sticky lg:top-6 lg:self-start">
            <div class="rounded-3xl border-[3px] border-black bg-pyellow p-5 shadow-card">
              <p class="text-sm font-semibold uppercase tracking-wide text-pblack">Written by</p>
              <h2 class="mt-2 text-2xl font-bold">seasKanon</h2>
              <p class="mt-2 text-sm leading-6 text-pblack">Notes from a long-running garden of mathematics, code, culture, and projects.</p>
            </div>
            {relatedPosts.length > 0 && (
              <div class="rounded-3xl border-[3px] border-black bg-ppink p-5 shadow-card">
                <h2 class="text-xl font-bold">Related</h2>
                <div class="mt-4 flex flex-col gap-4">
                  {relatedPosts.slice(0, 3).map((related, index) => (
                    <ArticleCard post={related} color={colors[index % colors.length]} />
                  ))}
                </div>
              </div>
            )}
          </aside>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
